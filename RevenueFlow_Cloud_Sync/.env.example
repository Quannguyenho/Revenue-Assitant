HOST=127.0.0.1
PORT=8790
NODE_ENV=development

# Required for extension/cloud clients. Use a long random value in production.
API_TOKEN=change-me-long-random-token

# Comma-separated origins allowed to call Cloud Sync.
# For local extension development, add chrome-extension://<extension-id> after install.
ALLOWED_ORIGINS=http://127.0.0.1:8790

# Internal/company PayPal API mode.
# For global customer OAuth/partner mode, see docs/CLOUD_SYNC_ARCHITECTURE.md.
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_LOOKBACK_DAYS=7

DATA_DIR=data
